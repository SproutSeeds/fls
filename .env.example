# Copy to `.env.local` (recommended) and fill in your values.
# Make sure `.env.local` is in your project's `.gitignore`.

# Optional: increases Semantic Scholar rate limits
FLS_SEMANTIC_SCHOLAR_API_KEY=your-key-here

# Required for Unpaywall requests (must be a real email you control)
FLS_UNPAYWALL_EMAIL=you@yourdomain.com
